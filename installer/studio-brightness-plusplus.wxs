<?xml version="1.0" encoding="UTF-8"?>
<!-- Per-machine MSI with a visible WixUI feature-tree installer.
     Version, exe path and license path are passed in by tools/build-msi.ps1
     via -d ProductVersion=... -d ExeSource=... -d LicenseRtf=...
     The UpgradeCode is fixed forever so each new MSI cleanly replaces the previous install. -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Studio Brightness++"
           Manufacturer="LitteRabbit-37"
           Version="$(var.ProductVersion)"
           UpgradeCode="AE421BD1-A6FD-4D6F-803B-70289E6848BC"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Studio Brightness++ is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPURLINFOABOUT" Value="https://github.com/LitteRabbit-37/Studio-Brightness-PlusPlus" />

    <!-- Application files. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Studio Brightness++">
        <Component Id="MainExe">
          <File Id="MainExeFile" Source="$(var.ExeSource)" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut (always installed). -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut">
        <Shortcut Id="StartSc" Name="Studio Brightness++"
                  Target="[INSTALLFOLDER]studio-brightness-plusplus.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanupStart" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\StudioBrightnessPlusPlus\Install"
                       Name="startMenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Desktop shortcut (optional: the user can uncheck the "Desktop shortcut" feature). -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComp">
        <Shortcut Id="DesktopSc" Name="Studio Brightness++"
                  Target="[INSTALLFOLDER]studio-brightness-plusplus.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanupDesktop" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\StudioBrightnessPlusPlus\Install"
                       Name="desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Wipe the installing user's settings on uninstall (data wipe).
         Limitation: a per-machine MSI only reaches the uninstalling user's HKCU hive. -->
    <Component Id="SettingsCleanup" Directory="INSTALLFOLDER">
      <RegistryKey Root="HKCU" Key="Software\StudioBrightnessPlusPlus" ForceDeleteOnUninstall="yes">
        <RegistryValue Name="Installed" Type="integer" Value="1" KeyPath="yes" />
      </RegistryKey>
    </Component>

    <Feature Id="MainApp" Title="Studio Brightness++" Level="1" AllowAbsent="no">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="SettingsCleanup" />
    </Feature>
    <Feature Id="DesktopShortcut" Title="Desktop shortcut"
             Description="Add a shortcut on the desktop." Level="1" AllowAbsent="yes">
      <ComponentRef Id="DesktopShortcutComp" />
    </Feature>

    <!-- "Launch Studio Brightness++ now" checkbox on the final page. -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Studio Brightness++ now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <CustomAction Id="LaunchApplication" FileRef="MainExeFile" ExeCommand="" Return="asyncNoWait" Impersonate="yes" />

    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />
    <ui:WixUI Id="WixUI_FeatureTree" />
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>
  </Package>
</Wix>
